POSTGRES_USER=change_me
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=moneyflow
DATABASE_URL=postgresql+psycopg://change_me:change_me_strong_password@postgres:5432/moneyflow
SECRET_KEY=change-this-to-a-random-secret-with-32-plus-bytes
ENV=prod
AUTH_COOKIE_SECURE=true
FORWARDED_ALLOW_IPS=172.30.0.0/24,127.0.0.1,::1
CORS_ORIGINS=https://moneyflow.enmsoftware.com
FRONTEND_BASE_URL=https://moneyflow.enmsoftware.com
ALLOW_SELF_SIGNED_TLS=false
AUTH_EMAIL_VERIFICATION_REQUIRED=true
AUTH_VERIFICATION_TOKEN_MINUTES=30
AUTH_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
AUTH_DEBUG_RETURN_VERIFY_TOKEN=false
HOUSEHOLD_INVITATION_TOKEN_HOURS=72
HOUSEHOLD_INVITATION_RATE_LIMIT_WINDOW_SECONDS=600
HOUSEHOLD_INVITATION_RATE_LIMIT_MAX_ATTEMPTS=20
WS_MEMBERSHIP_RECHECK_SECONDS=1.0
REGISTER_RATE_LIMIT_WINDOW_SECONDS=300
REGISTER_RATE_LIMIT_MAX_ATTEMPTS=10
REGISTER_UNVERIFIED_TTL_HOURS=24
EMAIL_DELIVERY_MODE=smtp
SMTP_HOST=email-smtp.ap-northeast-2.amazonaws.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_STARTTLS=true
SMTP_SSL=false
SMTP_FROM_EMAIL=no-reply@enmsoftware.com
SMTP_FROM_NAME=money-flow
SMTP_ACCOUNT_LABEL=money-flow-prod

# Live mail E2E (set only in local shell session; do not commit secrets)
MAIL_LIVE_GMAIL_EMAIL=
MAIL_LIVE_GMAIL_PASSWORD=
MAIL_LIVE_GMAIL_SECONDARY_EMAIL=
MAIL_LIVE_GMAIL_SECONDARY_PASSWORD=
MAIL_LIVE_NAVER_EMAIL=
MAIL_LIVE_NAVER_PASSWORD=
MAIL_LIVE_APP_PASSWORD=
MAIL_LIVE_TIMEOUT_SEC=240
MAIL_LIVE_ROUNDS=all
MAIL_LIVE_IDENTITY_MODE=cross_provider
MAIL_LIVE_GMAIL_ALIAS_PREFIX=mail-live-e2e
MAIL_LIVE_SMTP_SENDER=auto
MAIL_LIVE_SMTP_ACCOUNT_LABEL=dedicated
MAIL_LIVE_SMTP_EMAIL=no-reply@enmsoftware.com
# For SES dedicated sender, set to SES SMTP username (if different from MAIL_LIVE_SMTP_EMAIL).
MAIL_LIVE_SMTP_AUTH_EMAIL=
MAIL_LIVE_SMTP_PASSWORD=
MAIL_LIVE_SMTP_AUTH_ENABLED=true
MAIL_LIVE_SMTP_HOST=email-smtp.ap-northeast-2.amazonaws.com
MAIL_LIVE_SMTP_PORT=587
MAIL_LIVE_SMTP_STARTTLS=true
MAIL_LIVE_SMTP_SSL=false
MAIL_LIVE_USE_DEBUG_TOKENS=false
